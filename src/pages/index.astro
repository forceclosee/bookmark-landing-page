---
import Layout from "@layouts/Layout.astro";

import Hero from "@components/MainContent/Hero.astro";
import Features from "@components/MainContent/Features";
import ButtonLink from "@components/shared/ButtonLink.astro";
import BgShape from "@components/MainContent/BgShape.astro";
import Extension from "@components/MainContent/Extension.astro";
import Faq from "@components/MainContent/Faq.astro";
import ContactUs from "@components/MainContent/ContactUs.astro";

import "@styles/pages/index.css";
---

<Layout>
	<main class="content">
		<div class="content__wrapper">
			<Hero />
			<Features client:load>
				<BgShape isReverse />
				<ButtonLink href="#" class="feature-content__button-link">
					More Info
				</ButtonLink>
			</Features>
			<Extension />
			<Faq />
			<ContactUs />
		</div>
	</main>
</Layout>
