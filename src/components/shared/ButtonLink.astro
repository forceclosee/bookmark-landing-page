---
import "@components/shared/ButtonLink.css";

export interface Props {
  href: string;
  variant?: "primary" | "secondary";
}
const { href, variant = "primary" } = Astro.props;
---

<a
  href={href}
  class:list={[
    "button-link",
    { "button-link--primary": variant === "primary" },
    { "button-link--secondary": variant === "secondary" },
  ]}>
  <slot />
</a>
