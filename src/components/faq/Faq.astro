---
import ButtonLink from "@components/shared/ButtonLink.astro";

import { faq } from "@data/data-faq";

import "@components/faq/Faq.css";
---

<section class="faq">
	<header class="faq__header flow">
		<h2 class="faq__title">Frequently Asked Questions</h2>
		<p class="faq__description">
			Here are some of our FAQs. If you have any other questions you’d like
			answered please feel free to email us.
		</p>
	</header>
	<div class="faq__details-wrapper">
		{faq.map((data) =>(
      <details name="faq" class="faq__details">
        <summary class="faq__summary">
					<span class="faq__summary-title">
						{data.title}
					</span>
					<span class="faq__summary-icon">
						<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="12" viewBox="0 0 18 12"><path fill="none" stroke="currentColor" stroke-width="3" d="M1 1l8 8 8-8"/>
						</svg>
					</span>
				</summary>
	      <p class="faq__content">{data.content}</p>
      </details>
    ))}
	</div>
	<ButtonLink href="#">More Info</ButtonLink>
</section>
